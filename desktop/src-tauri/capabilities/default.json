{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/calsync", "sidecar": true, "args": true }]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "shell:allow-open",
    "updater:default",
    "process:allow-restart"
  ]
}
