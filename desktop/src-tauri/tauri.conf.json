{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "calsync",
  "version": "0.3.1",
  "identifier": "com.btajp.calsync.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "calsync",
        "width": 980,
        "height": 700,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* ipc: http://ipc.localhost; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCMjk1ODU2ODZGRDc3MTMKUldRVGQvMkdWbGdwNjZNR3ZjZ1U4MmxHSGhrSnNhVFlhUzl1R2FGaGtuOW9TdmtUZlA1QTdtQmkK",
      "endpoints": ["https://github.com/btajp/calsync/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/calsync"],
    "icon": ["icons/icon.icns"]
  }
}
